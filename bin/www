#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('mapyourmeds-ips:server');
var http = require('http');
var { initPools, closePools } = require('../db/pool');
var { startupSelfTest } = require('../db/selfTest');
var logger = require('../utils/logger');

// Graceful shutdown: close pools before exit.
function shutdown(signal) {
  logger.info('[server] ' + signal + ' received, shutting down');
  closePools().finally(function () { process.exit(0); });
}
process.on('SIGINT', function () { shutdown('SIGINT'); });
process.on('SIGTERM', function () { shutdown('SIGTERM'); });

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * Bootstrap: warm the pool, run the startup DB self-test (H2 — in fail-fast
 * mode a degraded DB exits the process instead of silently serving empty data),
 * then start listening.
 */
async function bootstrap() {
  await initPools();
  await startupSelfTest(); // may process.exit(1) in fail-fast mode
  server.listen(port);
  server.on('error', onError);
  server.on('listening', onListening);
}

bootstrap().catch(function (err) {
  logger.error('[server] bootstrap failed: ' + (err && err.message));
  process.exit(1);
});

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
}
