<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy (ARR + URL Rewrite) -> Node/PM2 on :3000.
  Tuned for the IPS API's slow / large responses (~120s, up to ~70 MB) so IIS
  does not 502 on them. See iis/README.md.

  NOTE: the ARR PROXY TIMEOUT is a SERVER-LEVEL setting and CANNOT be set here.
  It defaults to 30s and is the usual cause of 502 on slow endpoints. Set it on
  the server node (IIS Manager -> Application Request Routing Cache -> Server
  Proxy Settings -> Time-out = 300) OR via appcmd:
    appcmd set config -section:system.webServer/proxy /timeout:"00:05:00" /commit:apphost
-->
<configuration>
    <system.web>
        <!-- Classic request timeout (seconds) for slow proxied requests. -->
        <httpRuntime executionTimeout="600" maxRequestLength="102400" />
    </system.web>
    <system.webServer>
        <security>
            <requestFiltering>
                <!-- Allow large responses (~70 MB). 104857600 = 100 MB headroom. -->
                <requestLimits maxAllowedContentLength="104857600" />
            </requestFiltering>
        </security>
        <rewrite>
            <rules>
                <rule name="ReverseProxyInboundRule1" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://localhost:3000/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
