# ---------------------------------------------------------------------------
# mapyourmeds_ips — environment config (copy to .env on the on-prem server)
# Do NOT commit the real .env. All values overridable; defaults match the
# proven scaffold connection (DSN=pelmeds_prod;UID=pelham;PWD=pelham).
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database (Sybase SQL Anywhere via ODBC) -------------------------------
# The registered ODBC DSN on the server. Main IPS data + drug data share it.
IPS_DSN=pelmeds_prod
IPS_UID=pelham
IPS_PWD=pelham

# Drug datasource — leave blank to reuse the IPS DSN (default). Set only if the
# client splits drug data onto a separate DSN.
# DRUG_DSN=
# DRUG_UID=
# DRUG_PWD=

# Optional extra ODBC connection-string options (appended verbatim), e.g. CharSet.
# ODBC_EXTRA=

# Connection pool sizing — tune to load.
DB_POOL_INITIAL=2
DB_POOL_MAX=10

# Cursor fetch batch size for LARGE result sets (rows per fetch). Large IPS
# endpoints (e.g. Cycle/Getcyclerx_status, ~15-70 MB) use cursor paging to avoid
# the odbc "out of memory" error. Bigger = fewer round-trips (faster) but more
# memory per batch.
DB_CURSOR_FETCH_SIZE=5000

# --- Long-running / large-response timeouts (ms) ---------------------------
# Some stored procs are slow (~120s) and large (up to ~70 MB). Raise Node's
# server timeouts so they aren't cut off. The IIS reverse-proxy timeout must
# ALSO be raised (server-level ARR proxyTimeout — see iis/README.md).
SERVER_TIMEOUT_MS=300000       # overall socket timeout (5 min)
REQUEST_TIMEOUT_MS=0           # 0 = no per-request limit
KEEPALIVE_TIMEOUT_MS=310000    # keep proxy<->node sockets open (> proxy idle)
HEADERS_TIMEOUT_MS=320000      # must be > keepAliveTimeout

# Only set if the SQL Anywhere license requires the Meditab auth option per
# connection (the registered DSN normally carries it — leave blank otherwise).
# DB_CONNECTION_INIT_SQL=SET TEMPORARY OPTION CONNECTION_AUTHENTICATION='Company=Meditab Software,Inc.;Application=PLabel;Signature=...'

# --- Auth (JWT) — used only by the core routes (Phase 4) -------------------
# CHANGE this secret in production.
JWT_SECRET=GciOiJIU
TOKEN_EXPIRATION_MIN=3

# --- CORS ------------------------------------------------------------------
CORS_ORIGIN=*

# --- Startup self-test / hardening -----------------------------------------
# On boot, run SELECT 1 + a canonical SP through the live code path.
STARTUP_DB_SELFTEST=1
# Refuse to start (exit 1) if the self-test fails — so a degraded DB never
# silently serves empty data. Default ON when NODE_ENV=production. SET THIS IN PROD.
STARTUP_DB_FAIL_FAST=1
# The stored proc used by the self-test (must return rows on a healthy DB).
STARTUP_SELFTEST_SP=sp_mym_getfacilitygroup
# Surface underlying err.message in JSON error responses (handy for smoke tests;
# keep 0 in normal prod operation).
DEBUG_ERRORS=0

# --- Smoke test ------------------------------------------------------------
# A valid Rx number on this DB for the parameterized-proc check (npm run smoke).
SMOKE_RX=50078646
